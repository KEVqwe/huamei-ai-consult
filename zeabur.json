{
  "cdn": {
    "enabled": true,
    "paths": ["/assets/**", "/lqip/**"],
    "cacheControl": "public, max-age=2592000, immutable"
  },
  "server": {
    "compression": {
      "brotli": true,
      "gzip": true
    }
  },
  "build": {
    "command": "npm install"
  },
  "start": {
    "command": "node app/server.js"
  }
}
